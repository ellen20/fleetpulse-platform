{
  "name": "fleetpulse-api",
  "version": "1.0.0",
  "description": "FleetPulse EV Fleet Management API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:init": "node db/init.js",
    "db:seed": "node db/seed.js",
    "db:reset": "node db/init.js && node db/seed.js",
    "test:pact:verify": "jest tests/pact --forceExit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.2.0",
    "jest": "^30.2.0"
  }
}
